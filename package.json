{
  "type": "module",
  "scripts": {
    "css-build": "sass --no-source-map src/popup/popup.scss src/popup/popup.css",
    "css-watch": "npm run css-build -- --watch",
    "start": "npm run css-watch",
    "lint": "eslint . --ignore-path .eslintignore",
    "test": "vitest run",
    "mutate": "stryker run",
    "mutate:report": "stryker run && node scripts/mutation-report.js"
  },
  "devDependencies": {
    "@creativebulma/bulma-divider": "^1.1.0",
    "@creativebulma/bulma-tooltip": "^1.2.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@yaireo/tagify": "^4.1.1",
    "bulma": "^0.9.2",
    "bulma-switch": "^2.0.0",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "jsdom": "^29.1.1",
    "prettier": "^2.4.1",
    "sass": "^1.80.4",
    "vitest": "^4.1.8"
  },
  "release": {
    "branches": [
      "main"
    ]
  }
}
